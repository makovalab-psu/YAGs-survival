       "data/gene_list/chimp_gene_list.csv",
       "data/gene_list/sum_orang_gene_list.csv",
       "data/gene_list/bor_orang_gene_list.csv",
       "data/gene_list/gor_gene_list.csv",
       "data/reference_genomes/bonobo/chrY.gff",
       "data/reference_genomes/human/chrY.gff",
       "data/reference_genomes/gor/chrY.gff",
       "data/reference_genomes/chimp/chrY.gff",
       "data/reference_genomes/bor_orang/chrY.gff",
       "data/reference_genomes/sum_orang/chrY.gff",
       "lastz_all_Y_transcripts/{species}_lastz.Ychr.lastz"
