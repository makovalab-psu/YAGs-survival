#unite fasta files across all species for each gene family
rule unite_fasta:
    input:
        chimp="data/fasta/ORFs/protein_db/chimp_techrep1_{gene_fam}_mod.fasta",
        bor_orang="data/fasta/ORFs/protein_db/bor_orang_techrep1_{gene_fam}_mod.fasta",
        sum_orang="data/fasta/ORFs/protein_db/sum_orang_techrep1_{gene_fam}_mod.fasta",
        human="data/fasta/ORFs/protein_db/human_orang_techrep1_{gene_fam}_mod.fasta",
        gor="data/fasta/ORFs/protein_db/gor_orang_techrep1_{gene_fam}_mod.fasta",
        bonobo="data/fasta/ORFs/protein_db/bonobo_orang_techrep1_{gene_fam}_mod.fasta"
    output:
        "data/fasta/ORFs/protein_db/{gene_fam}_united.fasta"
    shell:
        "cat {input.chimp} {input.bor_orang} {input.sum_orang} {input.human} {input.gor} {input.bonobo} > {output}"

#add information about species and gene fmaily to the name of each entry in the fasta file
rule modify_fasta:
    input:
        "data/fasta/ORFs/protein_db/{species}_techrep1_{gene_fam}_extracted.fasta"
    output:
        "data/fasta/ORFs/protein_db/{species}_techrep1_{gene_fam}_mod.fasta"
    shell:
        "bash scripts/modify_fasta.sh {input} {output}"

#extract seuqneces of predicted proteins
rule extract_orf_fasta:
    input:
        id_file="data/fasta/ORFs/protein_db/{species}_techrep1_{gene_fam}.txt",
        fasta="data/fasta/ORFs/{species}_techrep1.stringtie.Ychr.orf"
    output:
        "data/fasta/ORFs/protein_db/{species}_techrep1_{gene_fam}_extracted.fasta"
    shell:
        "bash scripts/extract_protein_orfs_fasta.sh {input.id_file} {input.fasta} {output}"

#compare each isoform against the reference to count the number of unique isoforms
rule isoform_comapre:
     input:
        "compare_isoforms/{gene_fam}/{gene_fam}_transcripts.gff"
     output:
        "compare_isoforms/{gene_fam}/transcript_1.{gene_fam}_transcripts.gff.tmap"
     shell:
        """
        bash scripts/isoform_compare.sh {wildcards.gene_fam}
        """

#subset each transcript into a separate gtf file
rule subset_gff:
      input:
         gff="stringtie/annotation_upd/merged_gff_cORF/{species}_{techrep}.stringtie.annotation.hc_cORF.Ychr.gff"
      output:
         all="stringtie/annotation/final/annotation_subset/{species}_{techrep}_{gene_fam}.all.Ychr.gff"
      shell:
         "Rscript scripts/subset_gtf_hc_cORF.R {wildcards.species} {wildcards.techrep} {wildcards.gene_fam} {input.gff} {output.all}"

#bed data into gtf
rule bed_to_gff_isoforms:
    input:
        bed="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.sorted.bed"
    output:
        gff="compare_isoforms/{gene_fam}/{gene_fam}_transcripts.gff",
        path="compare_isoforms/{gene_fam}/"
    shell:
        "Rscript scripts/bed_to_gff_transcripts.R {wildcards.gene_fam} {input.bed} {output.gff} {output.path}"

