#align sequences of assembled transcripts to all YAG transcripts (to confirm the prediction of potential novel YAG copies)
rule lastz_call_all_Y_transcript:
    input:
        "data/fasta/{species}_corrected.fasta"
    output:
        "lastz_all_Y_transcripts/{species}_lastz.Ychr.lastz"
    shell:
        "lastz {input}[multiple] data/lastz_data/all_apes_chrY_transcripts.fasta --format=general:name1,zstart1,end1,name2,strand2,zstart2+,end2+,id%,blastid%,coverage > {output}"

#get fasta sequences of all Y transcripts
rule subset_gff_to_fasta:
      input:
         gff = "stringtie/annotation/final/annotation_subset/{species}_techrep1_{gene_fam}.all.Ychr.gff",
         ref = "data/reference_genomes/{species}/genomic.fna"
      output:
         "stringtie/annotation/final/annotation_subset/fasta/{species}_techrep1_{gene_fam}.all.Ychr.fasta"
      shell:
         "/galaxy/home/ajg7274/tools/gffread/gffread/gffread -w {output} -g {input.ref} {input.gff}"


