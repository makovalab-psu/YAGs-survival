#align sequences of assembled transcripts to known YAG transcripts
rule lastz_call:
    input:
        "data/fasta/{species}_corrected.fasta"
    output:
        "lastz/{species}_lastz.upd.Ychr.lastz"
    shell:
        "lastz {input}[multiple] data/great_apes_YAGs/all_species_YAGs.fasta --format=general:name1,zstart1,end1,name2,strand2,zstart2+,end2+,id%,blastid%,coverage > {output}"

