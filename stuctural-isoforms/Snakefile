rule samtools_uLTRA_mapping_bam_to_bed:
     input:
        sorted="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.sorted.bam"
     output:
        bed="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.sorted.bed"
     shell:
        "/galaxy/home/marta/conda/envs/bedtools/bedtools2/bin/bamToBed -i {input.sorted} -split > {output.bed}"


rule samtools_uLTRA_mapping_index:
     input:
        sorted="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.sorted.bam"
     output:
        bai="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.sorted.bam.bai"
     shell:
        "samtools index {input.sorted}"

rule samtools_uLTRA_mapping_bam_sort:
     input:
        bam="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.bam"
     output:
        sorted="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.sorted.bam"
     shell:
        "samtools sort {input.bam} > {output.sorted}"

rule samtools_uLTRA_mapping_sam_to_bam:
      input:
        sam="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.sam"
      output:
        bam="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.bam"
      shell:
        "samtools view -Sb {input.sam} > {output.bam}"

rule uLTRA_mapping:
      input:
         fa="data/ultra/human_gene_copies.fa",
         vcf="/nfs/brubeck.bx.psu.edu/scratch6/marta/Whole_genome_Hsa/hg38_chrY.vcf",
         fasta="stringtie/annotation/final/annotation_subset/fasta/merged/{gene_fam}.merged.all.Ychr.fasta"
      output:
         ultra="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/",
         next_step="stringtie/annotation/final/annotation_subset/fasta/merged/uLTRA/{gene_fam}_ultra/reads.sam"
      shell:
         "/nfs/thumper.galaxyproject.org/home/marta/conda/envs/ultra/bin/uLTRA pipeline {input.fa} {input.vcf} {input.fasta} {output.ultra} --t 40"

rule merge_fasta:
      input:
         chimp="stringtie/annotation/final/annotation_subset/fasta/chimp_techrep1_{gene_fam}.all.Ychr.fasta",
         bonobo="stringtie/annotation/final/annotation_subset/fasta/bonobo_techrep1_{gene_fam}.all.Ychr.fasta",
         gor="stringtie/annotation/final/annotation_subset/fasta/gor_techrep1_{gene_fam}.all.Ychr.fasta",
         bor_orang="stringtie/annotation/final/annotation_subset/fasta/bor_orang_techrep1_{gene_fam}.all.Ychr.fasta",
         sum_orang="stringtie/annotation/final/annotation_subset/fasta/sum_orang_techrep1_{gene_fam}.all.Ychr.fasta",
         human="stringtie/annotation/final/annotation_subset/fasta/human_techrep1_{gene_fam}.all.Ychr.fasta"
      output:
         "stringtie/annotation/final/annotation_subset/fasta/merged/{gene_fam}.merged.all.Ychr.fasta"
      shell:
         "cat {input.chimp} {input.bonobo} {input.gor} {input.bor_orang} {input.sum_orang} {input.human} > {output}"

#run gffcompare to determine the origin (targeted technical replicate 1 or 2 or untargeted data) in the final assembly
rule gffcompare:
    input:
        reference_gff="compare_with_original/reference/{species}_techrep1.stringtie.annotation.hc_cORF.Ychr.gff",
        targeted1_gff="compare_with_original/targeted/{species}_techrep1.stringtie.Ychr.gtf",
        targeted2_gff="compare_with_original/targeted/{species}_techrep2.stringtie.Ychr.gtf",
        untargeted_gff="compare_with_original/untargeted/{species}_techrep1.stringtie.Ychr.gtf"
    output:
        targeted1_stats="compare_with_original/{species}_targeted1.stats",
        targeted2_stats="compare_with_original/{species}_targeted2.stats",
        untargeted_stats="compare_with_original/{species}_untargeted.stats"
    params:
        gffcompare_path="/galaxy/home/ajg7274/tools/gffcompare/gffcompare/gffcompare"
    shell:
        """
        # Run gffcompare for targeted1 GFF
        {params.gffcompare_path} -r {input.reference_gff} -o compare_with_original/{wildcards.species}_targeted1 {input.targeted1_gff}

        # Run gffcompare for targeted2 GFF
        {params.gffcompare_path} -r {input.reference_gff} -o compare_with_original/{wildcards.species}_targeted2 {input.targeted2_gff}

        # Run gffcompare for untargeted GFF
        {params.gffcompare_path} -r {input.reference_gff} -o compare_with_original/{wildcards.species}_untargeted {input.untargeted_gff}
        """

#copy files to the directory
rule copy_gff_files:
    input:
        lambda wildcards: f"stringtie/annotation_upd/merged_gff_cORF/{wildcards.species}_{wildcards.techrep}.stringtie.annotation.hc_cORF.Ychr.gff"
    output:
        "compare_with_original/reference/{species}_{techrep}.stringtie.annotation.hc_cORF.Ychr.gff"
    run:
        shell("cp {input} {output}")

