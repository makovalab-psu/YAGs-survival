#annotated high-confidence cORFs in the transcript assemblies
rule merge_gff_hc_cORF:
     input:
        "protein_db/protein_lengths.tsv",
        "protein_db/human_apes_Y_NCBI.tsv",
        "stringtie/annotation_upd/final/{species}_{techrep}.stringtie.annotation.final.Ychr.gff",
        "data/fasta/ORFs/protein_db/{species}_{techrep}_Y_homologs.Ychr.txt"
     output:
        "stringtie/annotation_upd/merged_gff_cORF/{species}_{techrep}.stringtie.annotation.hc_cORF.Ychr.gff"
     script:
        "scripts/merge_gff_hc_cORF_old_version.R"

#identify high-confidence cORFs based on
#homology between predicted protein sequences and know YAG proteins from NCBI protein data base 
rule Y_proteins_homology:
      input:
         "data/fasta/ORFs/{species}_{techrep}.stringtie.Ychr.orf"
      output:
         "data/fasta/ORFs/protein_db/{species}_{techrep}_Y_homologs.Ychr.txt"
      shell:
          "blastp -query {input} -db protein_db/human_apes_YAGs -out {output} -evalue 1e-30 -outfmt \"6 qseqid sseqid qcovs length pident evalue bitscore mismatch gaps qstart qend sstart send qseq sseq qlen\""

#add information about potential ORFs to transcript assmblies
rule final_annotation:
    input:
       "data/fasta/ORFs/{species}_{techrep}.stringtie.Ychr.orf",
       "stringtie/annotation_upd/{species}_{techrep}.stringtie.annotation.Ychr.gff",
       "data/fasta/{species}_corrected.fasta"
    output:
       "stringtie/annotation_upd/final/{species}_{techrep}.stringtie.annotation.final.Ychr.gff"
    script:
       "scripts/annotation_final.R"

#fins potential ORFs
rule find_ORFs:
    input:
       "data/fasta/{species}_corrected.fasta"
    output:
       "data/fasta/ORFs/{species}_{techrep}.stringtie.Ychr.orf"
    shell:
       "getorf -sequence {input} -minsize 150 -find 1 -outseq {output}"

