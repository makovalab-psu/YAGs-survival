#move merged gtfs into the directory
rule move_merged_gtf:
    input:
        expand("MERGED_{species}.combined.gtf", species=config["species"])
    output:
        "/stringtie_merged"
    shell:
        "mv {input} {output}"

#merge stringtie assemblies from targeted technical replicate 1 and 2 and untargeted IsoSeq data
rule merge_gff:
    input:
        trageted1="stringtie_targeted/{species}_techrep1.stringtie.Ychr.gtf",
        trageted2="stringtie_targeted/{species}_techrep2.stringtie.Ychr.gtf",
        untargeted="stringtie_untargeted/{species}_techrep1.stringtie.Ychr.gtf"
    output:
        prefix="MERGED_{species}",
        folder="stringtie_merged/MERGED_{species}",
        targeted_file="MERGED_{species}.combined.gtf"
    shell:
        """
        mkdir {output.folder}
        /galaxy/home/ajg7274/tools/gffcompare/gffcompare/gffcompare {input.trageted1} {input.trageted2} {input.untargeted} -o {output.prefix}
        """

